---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations } from '../../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);
const filterLocale = locale === 'en' ? 'en' : 'es';
const prefix = locale === 'en' ? '/en' : '';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map(p => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);

if (!post) return Astro.redirect(locale === 'en' ? '/en/404' : '/404');

const { title, description, publishedAt, tags, author } = post.data;
const { Content } = await render(post);

const dateLocale = locale === 'en' ? 'en-US' : 'es-CO';
const formattedDate = publishedAt.toLocaleDateString(dateLocale, {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<BaseLayout title={`${title} — Tp3studio Blog`} description={description} breadcrumbLabel={title} locale={locale}>
  <article class="section">
    <div class="post-inner container">
      <a href={`${prefix}/blog`} class="back-link">&larr; {t.blog.backLink}</a>

      <header class="post-header">
        <div class="post-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <h1>{title}</h1>
        <div class="post-meta">
          <span>{formattedDate}</span>
          <span aria-hidden="true">·</span>
          <span>{author}</span>
        </div>
      </header>

      <div class="post-body">
        <Content />
      </div>

      <hr class="post-divider" />

      <div class="post-cta">
        <p>{locale === 'en' ? 'Want your own website with chatbot? Let\'s talk.' : '¿Quieres tu propia web con chatbot? Hablemos.'}</p>
        <a href={`${prefix}/precios`} class="btn-creative btn-primary btn-md">{locale === 'en' ? 'See plans from $100 USD' : 'Ver planes desde $100 USD'}</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
.post-inner { max-width: 42rem; }

.back-link {
  display: inline-block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 2rem;
}
.back-link:hover { color: var(--color-primary-hover); }

.post-header { margin-bottom: 2.5rem; }

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-bottom: 1rem;
}

.tag {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.2rem 0.55rem;
  border-radius: var(--radius-full);
  background: rgba(99, 102, 241, 0.08);
  color: var(--color-primary);
}

.post-header h1 {
  font-size: 2.25rem;
  line-height: 1.2;
  margin-bottom: 0.75rem;
}

.post-meta {
  display: flex;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: rgba(15, 14, 26, 0.45);
}

.post-body {
  font-size: 1.0625rem;
  line-height: 1.85;
  color: rgba(15, 14, 26, 0.8);
}

.post-body :global(h2) {
  font-size: 1.5rem;
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
}

.post-body :global(p) {
  margin-bottom: 1.5rem;
}

.post-body :global(strong) {
  color: var(--color-fg);
}

.post-divider {
  border: none;
  border-top: 1px solid var(--color-border);
  margin: 3rem 0;
}

.post-cta {
  text-align: center;
}
.post-cta p {
  font-size: 1.0625rem;
  color: rgba(15, 14, 26, 0.6);
  margin-bottom: 1rem;
}
</style>
