---
/**
 * Breadcrumbs.astro
 *
 * Breadcrumb navigation con schema.org BreadcrumbList.
 *
 * Uso en páginas estáticas:
 *   <Breadcrumbs pathname={Astro.url.pathname} />
 *
 * Uso en páginas dinámicas (blog/[slug], portfolio/[slug]):
 *   <Breadcrumbs pathname={Astro.url.pathname} currentLabel="Nombre del artículo/caso" />
 *
 * La homepage (/) no muestra breadcrumbs.
 * 404 no debe incluir este componente.
 */

export interface Props {
  pathname: string;
  /** Label para la página actual (dinámica) — ej: título del artículo o caso */
  currentLabel?: string;
}

const { pathname, currentLabel } = Astro.props;

// Mapa de rutas estáticas → etiquetas
const routeLabels: Record<string, string> = {
  '/blog': 'Blog',
  '/portfolio': 'Casos de Éxito',
  '/precios': 'Precios',
  '/audit': 'Auditoría Gratis',
  '/about': 'Nuestra Historia',
  '/preview': 'Prueba tu web',
  '/auth': 'Inicia Sesión',
};

// Construir la lista de breadcrumbs
const segments = pathname.split('/').filter(Boolean);
const crumbs: { label: string; href?: string }[] = [];

if (segments.length === 0 || pathname === '/') {
  // Homepage: no mostrar breadcrumbs
} else {
  // Siempre empezar con Inicio
  crumbs.push({ label: 'Inicio', href: '/' });

  let accumulated = '';
  for (let i = 0; i < segments.length; i++) {
    accumulated += '/' + segments[i];
    const isLast = i === segments.length - 1;

    if (!segments[i]) continue; // fallback

    if (isLast && currentLabel) {
      // Último segmento dinámico con etiqueta personalizada
      crumbs.push({ label: currentLabel });
    } else if (routeLabels[accumulated]) {
      crumbs.push({
        label: routeLabels[accumulated],
        href: isLast ? undefined : accumulated,
      });
    } else if (isLast && !currentLabel) {
      // Último segmento sin label conocido: mostrar formateado
      crumbs.push({ label: segments[i] });
    }
  }
}

const itemListElement = crumbs.map((crumb, i) => ({
  '@type': 'ListItem' as const,
  position: i + 1,
  name: crumb.label,
  ...(crumb.href ? { item: new URL(crumb.href, 'https://tp3studio.com').href } : {}),
}));
---

{
  crumbs.length > 0 && (
    <>
      {/* Schema.org BreadcrumbList */}
      <script is:inline>
        {`{
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": ${JSON.stringify(itemListElement)}
        }`}
      </script>

      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs-list">
          {crumbs.map((crumb, i) => (
            <li class="breadcrumbs-item">
              {crumb.href ? (
                <a href={crumb.href} class="breadcrumbs-link">{crumb.label}</a>
              ) : (
                <span class="breadcrumbs-current" aria-current="page">{crumb.label}</span>
              )}
              {i < crumbs.length - 1 && (
                <span class="breadcrumbs-sep" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M4.5 2.5L7.5 6L4.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </>
  )
}

<style>
.breadcrumbs {
  padding: 0.75rem 0 0;
}

.breadcrumbs-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.25rem;
}

.breadcrumbs-item {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.8125rem;
  line-height: 1;
}

.breadcrumbs-link {
  color: rgba(15, 14, 26, 0.5);
  text-decoration: none;
  font-weight: 500;
  transition: color 200ms;
  padding: 0.125rem 0.25rem;
  border-radius: 4px;
}

.breadcrumbs-link:hover {
  color: var(--color-clay);
  background: rgba(99, 102, 241, 0.06);
}

.breadcrumbs-current {
  color: var(--color-deep);
  font-weight: 600;
}

.breadcrumbs-sep {
  display: inline-flex;
  align-items: center;
  color: rgba(15, 14, 26, 0.25);
}
</style>
