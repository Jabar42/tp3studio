---
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '@tp3/chat-widget';
import '../styles/global.css';
import { getTranslations } from '../i18n';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  /** Breadcrumb label para la página actual (páginas dinámicas: blog/caso slug) */
  breadcrumbLabel?: string;
  /** Ocultar breadcrumbs en esta página (ej: 404, homepage) */
  hideBreadcrumbs?: boolean;
  /** Schema.org JSON-LD markup para inyectar en <head> */
  schema?: string;
  /** Locale override (default: Astro.currentLocale) */
  locale?: string;
}

const {
  title,
  description,
  ogImage = 'https://tp3studio.com/og-image.jpg',
  breadcrumbLabel,
  hideBreadcrumbs = false,
  schema,
  locale = Astro.currentLocale ?? 'es',
} = Astro.props;

const t = getTranslations(locale);
const lang = locale === 'en' ? 'en' : 'es';
const canonicalUrl = new URL(Astro.url.pathname, 'https://tp3studio.com').href;

const currentPath = Astro.url.pathname;
// Build hreflang URLs
const esUrl = lang === 'en' ? currentPath.replace(/^\/en/, '') || '/' : currentPath;
const enUrl = lang === 'es' ? '/en' + (currentPath === '/' ? '' : currentPath) : currentPath;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Tp3studio" />
    <meta name="keywords" content={lang === 'en' ? "AI business solutions, chatbot, WhatsApp Business, modern websites, business automation" : "soluciones IA negocios, chatbot, WhatsApp business, sitios web modernos, automatización empresarial, Colombia"} />

    <link rel="canonical" href={new URL(currentPath, 'https://tp3studio.com').href} />

    <!-- hreflang -->
    <link rel="alternate" href={new URL(esUrl, 'https://tp3studio.com').href} hrefLang="es" />
    <link rel="alternate" href={new URL(enUrl, 'https://tp3studio.com').href} hrefLang="en" />
    <link rel="alternate" href={new URL(esUrl, 'https://tp3studio.com').href} hrefLang="x-default" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_CO'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Umami Analytics -->
    <script defer src='https://umami-beta-livid.vercel.app/script.js' data-website-id='f896ea6e-7875-45ba-96df-01eec2029191'></script>
    {
      schema && <script is:inline type="application/ld+json" set:html={schema} />
    }
  </head>
  <body>
    <div class="grain-overlay" aria-hidden="true"></div>
    <Header lang={lang} />
    <main>
      {
        !hideBreadcrumbs && (
          <div class="container">
            <Breadcrumbs pathname={currentPath} currentLabel={breadcrumbLabel} lang={lang} />
          </div>
        )
      }
      <slot />
    </main>
    <Footer lang={lang} />
    <ChatWidget agentHost="tp3studio-chat.iaforchange.workers.dev" client:load />
  </body>
</html>

<style is:global>
  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
  }
</style>
