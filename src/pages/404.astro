---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);
const p = t.notFound;
const prefix = locale === 'en' ? '/en' : '';
---

<BaseLayout title={p.title + ' — Tp3studio'} description={p.description} hideBreadcrumbs locale={locale}>
  <section class="not-found">
    <div class="container not-found-inner">
      <span class="not-found-code">{p.code}</span>
      <h1>{p.message}</h1>
      <p>{p.details}</p>
      <div class="not-found-actions">
        <a href={prefix || '/'} class="btn-primary-hero">
          <span class="btn-primary-label">{p.home}</span>
          <span class="btn-primary-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="btn-shimmer" aria-hidden="true"></span>
        </a>
        <a href={locale === 'en' ? '/en/precios' : '/precios'} class="btn-whatsapp-hero">
          <span class="btn-wa-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
          </span>
          {locale === 'en' ? 'See plans from $100 USD' : 'Ver planes desde $100 USD'}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.not-found {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 4rem 0;
  text-align: center;
}
.not-found-inner {
  max-width: 32rem;
}
.not-found-code {
  display: block;
  font-family: var(--font-heading);
  font-size: 8rem;
  font-weight: 800;
  line-height: 1;
  background: linear-gradient(135deg, var(--color-terracotta), var(--color-sand));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 1rem;
}
.not-found h1 {
  font-size: 2rem;
  margin-bottom: 0.75rem;
}
.not-found p {
  font-size: 1.0625rem;
  color: rgba(15, 14, 26, 0.6);
  line-height: 1.7;
  margin-bottom: 2rem;
}
.not-found-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.85rem;
  justify-content: center;
}
</style>
