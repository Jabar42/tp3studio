---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const cases = await getCollection('portfolio');
  return cases.map(c => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('portfolio', slug!);

if (!entry) {
  return Astro.redirect('/404');
}

const { name, location, description, tags, url } = entry.data;
---

<BaseLayout
  title={`${name} — Tp3studio`}
  description={description}
>
  <section class="section">
    <div class="container detail-inner">
      <a href="/portfolio" class="back-link">&larr; Volver a Casos de Éxito</a>

      <article class="detail-card">
        <header class="detail-header">
          <div class="detail-tags">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
          <h1>{name}</h1>
          <p class="detail-location">{location}</p>
        </header>

        <div class="detail-body">
          <p class="detail-desc">{description}</p>

          {url && (
            <div class="detail-preview">
              <h2 class="detail-preview-title">Vista previa</h2>
              <div class="detail-iframe-wrap">
                <iframe
                  src={url}
                  title={`Vista previa de ${name}`}
                  loading="lazy"
                  sandbox="allow-scripts allow-same-origin"
                  class="detail-iframe"
                ></iframe>
              </div>
              <a href={url} target="_blank" rel="noopener noreferrer" class="detail-external-link">
                Visitar sitio &rarr;
              </a>
            </div>
          )}
        </div>
      </article>

      <div class="detail-cta">
        <a href="/precios" class="btn-creative btn-primary btn-md">
          Quiero resultados como estos &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.detail-inner {
  max-width: 42rem;
}

.back-link {
  display: inline-block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 2rem;
}
.back-link:hover { color: var(--color-primary-hover); }

.detail-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.detail-header {
  padding: 2.5rem 2.5rem 1.5rem;
  border-bottom: 1px solid var(--color-border);
  background: linear-gradient(180deg, var(--color-cream), #fff);
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.tag {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-full);
  background: rgba(99, 102, 241, 0.08);
  color: var(--color-primary);
}

.detail-header h1 {
  font-size: 2rem;
  margin-bottom: 0.35rem;
}

.detail-location {
  font-size: 0.9375rem;
  color: rgba(15, 14, 26, 0.45);
  margin: 0;
}

.detail-body {
  padding: 2rem 2.5rem;
}

.detail-desc {
  font-size: 1.125rem;
  line-height: 1.8;
  color: rgba(15, 14, 26, 0.75);
  margin: 0;
}

.detail-preview {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.detail-preview-title {
  font-size: 1.25rem;
  margin-bottom: 1rem;
}

.detail-iframe-wrap {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-muted);
}

.detail-iframe {
  width: 100%;
  height: 500px;
  border: none;
  display: block;
}

.detail-external-link {
  display: inline-block;
  margin-top: 1rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-primary);
}
.detail-external-link:hover { color: var(--color-primary-hover); }

.detail-cta {
  text-align: center;
  margin-top: 2.5rem;
}

@media (max-width: 480px) {
  .detail-header { padding: 1.75rem 1.5rem 1.25rem; }
  .detail-body { padding: 1.5rem; }
}
</style>
