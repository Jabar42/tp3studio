---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);
const p = t.audit;
---

<BaseLayout title={p.title} description={p.desc} locale={locale}>
  <section class="section"><div class="container audit-inner">
    <div class="audit-header">
      <span class="section-label">{p.heroLabel}</span>
      <h1>{p.heroTitle} <span class="accent-text">{p.heroHighlight}</span> {p.heroEnd}</h1>
      <p>{p.heroDesc}</p>
    </div>
    <form class="audit-form" action="/api/lead" method="POST">
      <div class="form-group">
        <label for="name">{p.form.name}</label>
        <input type="text" id="name" name="name" required placeholder={p.form.namePlaceholder} />
      </div>
      <div class="form-group">
        <label for="business">{p.form.business}</label>
        <input type="text" id="business" name="business" required placeholder={p.form.businessPlaceholder} />
      </div>
      <div class="form-group">
        <label for="email">{p.form.email}</label>
        <input type="email" id="email" name="email" required placeholder={p.form.emailPlaceholder} />
      </div>
      <div class="form-group">
        <label for="phone">{p.form.phone}</label>
        <input type="tel" id="phone" name="phone" placeholder={p.form.phonePlaceholder} />
      </div>
      <div class="form-group">
        <label for="website">{p.form.website}</label>
        <input type="url" id="website" name="website" placeholder={p.form.websitePlaceholder} />
      </div>
      <div class="form-group">
        <label for="message">{p.form.message}</label>
        <textarea id="message" name="message" rows="4" placeholder={p.form.messagePlaceholder}></textarea>
      </div>
      <button type="submit" class="audit-submit-btn">{p.form.submit}</button>
      <p class="form-disclaimer">{p.form.privacy}</p>
    </form>

    <div id="form-success" class="form-success" hidden>
      <div class="form-success-icon">✅</div>
      <h2>{p.form.success}</h2>
      <p>{locale === 'en' ? 'We will contact you within 24 hours. Meanwhile, check out our' : 'Te contactaremos en menos de 24 horas. Mientras tanto, puedes ver nuestros'}<a href={locale === 'en' ? '/en/portfolio' : '/portfolio'}> {locale === 'en' ? 'success stories' : 'casos de éxito'}</a>.</p>
    </div>
  </div></section>

  <script define:vars={{ sending: p.form.sending, errorMsg: p.form.error }}>
    const form = document.querySelector('.audit-form');
    const success = document.getElementById('form-success');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = sending;

      try {
        const resp = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form)),
        });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        form.style.display = 'none';
        success.hidden = false;
      } catch {
        btn.disabled = false;
        btn.textContent = errorMsg;
      }
    });
  </script>
</BaseLayout>

<style>
.audit-inner { max-width: 36rem; }
.audit-header { text-align: center; margin-bottom: 3rem; }
.audit-header p { font-size: 1.0625rem; color: rgba(45,26,15,0.6); margin-top: 1rem; }
.audit-form { display: flex; flex-direction: column; gap: 1.25rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; }
.form-group label { font-weight: 600; font-size: 0.9rem; }
.form-group input, .form-group select, .form-group textarea { padding: 0.75rem 1rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.9375rem; transition: border-color 200ms; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--color-primary); }
.form-disclaimer { font-size: 0.75rem; color: rgba(45,26,15,0.4); text-align: center; }
.audit-submit-btn {
  width: 100%;
  padding: 1rem 2rem;
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  font-family: var(--font-body);
  font-size: 1.0625rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 200ms, transform 150ms;
}
.audit-submit-btn:hover { background: var(--color-primary-dark, #4F46E5); transform: translateY(-1px); }
.audit-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.form-success { text-align: center; padding: 3rem 0; }
.form-success h2 { margin: 1rem 0 0.5rem; }
.form-success p { color: rgba(45,26,15,0.6); }
</style>
