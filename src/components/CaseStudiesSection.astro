---
import type en from '../i18n/en';

export interface Props {
  t: typeof en.caseStudies;
}

const { t } = Astro.props;
const cases = t.cases;
---

<section class="case-studies section" id="casos">
  <div class="container">
    <div class="cs-header">
      <span class="section-label">{t.label}</span>
      <h2>{t.title} <span class="accent-text">{t.titleHighlight}</span></h2>
      <p class="cs-subtitle">{t.subtitle}</p>
    </div>

    <div class="cs-tabs-wrapper">
      <!-- Tab buttons -->
      <div class="cs-tabs" role="tablist">
        {cases.map((c, i) => (
          <button
            class={`cs-tab ${i === 0 ? 'cs-tab--active' : ''}`}
            role="tab"
            data-index={i}
          >
            <span class="cs-tab-name">{c.tab}</span>
            <span class="cs-tab-industry">{c.industry}</span>
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div class="cs-panels">
        {cases.map((c, i) => (
          <div
            class={`cs-panel ${i === 0 ? 'cs-panel--active' : ''}`}
            role="tabpanel"
            data-index={i}
          >
            <div class="cs-panel-content">
              <div class="cs-panel-meta">
                <span class="cs-panel-location">{c.location}</span>
              </div>
              <h3 class="cs-panel-headline">{c.headline}</h3>
              <div class="cs-panel-results">
                {c.results.split(' · ').map(r => (
                  <span class="cs-result-tag">{r}</span>
                ))}
              </div>
              <p class="cs-panel-body">{c.body}</p>
              <a href={c.url} class="cs-panel-link" target="_blank" rel="noopener">
                {t.viewSite} <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 3h7v7M11 3L3 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const tabs = document.querySelectorAll('.cs-tab');
    const panels = document.querySelectorAll('.cs-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const idx = tab.dataset.index;
        tabs.forEach(t => t.classList.remove('cs-tab--active'));
        panels.forEach(p => p.classList.remove('cs-panel--active'));
        tab.classList.add('cs-tab--active');
        const panel = document.querySelector(`.cs-panel[data-index="${idx}"]`);
        if (panel) panel.classList.add('cs-panel--active');
      });
    });
  })();
</script>

<style>
.case-studies {
  background: var(--color-cream);
}

.cs-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 3rem;
}

.cs-subtitle {
  font-size: 1.0625rem;
  color: rgba(15, 14, 26, 0.55);
  margin-top: 0.5rem;
  line-height: 1.6;
}

/* Tabs */
.cs-tabs {
  display: flex;
  gap: 0.25rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 2rem;
}

.cs-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
  padding: 0.75rem 1.5rem;
  border: none;
  background: transparent;
  border-radius: var(--radius-lg);
  cursor: pointer;
  font-family: var(--font-body);
  transition: background 200ms, color 200ms;
  color: rgba(15, 14, 26, 0.5);
}

.cs-tab:hover {
  background: rgba(99, 102, 241, 0.06);
  color: var(--color-deep);
}

.cs-tab--active {
  background: #fff;
  color: var(--color-primary);
  box-shadow: 0 2px 12px rgba(99, 102, 241, 0.1);
}

.cs-tab-name {
  font-family: 'Outfit', sans-serif;
  font-size: 1rem;
  font-weight: 700;
}

.cs-tab-industry {
  font-size: 0.7rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  opacity: 0.6;
}

/* Panels */
.cs-panels {
  max-width: 780px;
  margin: 0 auto;
  background: #fff;
  border-radius: var(--radius-xl);
  border: 1.5px solid var(--color-border);
  overflow: hidden;
}

.cs-panel {
  display: none;
  padding: 2.5rem;
}

.cs-panel--active {
  display: block;
}

.cs-panel-meta {
  margin-bottom: 0.75rem;
}

.cs-panel-location {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-primary);
  background: rgba(99, 102, 241, 0.07);
  padding: 0.3rem 0.8rem;
  border-radius: var(--radius-full);
}

.cs-panel-headline {
  font-family: 'Outfit', sans-serif;
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--color-deep);
  line-height: 1.3;
  margin: 0 0 1rem;
}

.cs-panel-results {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.cs-result-tag {
  font-size: 0.75rem;
  font-weight: 600;
  color: #16A34A;
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  padding: 0.3rem 0.7rem;
  border-radius: var(--radius-full);
}

.cs-panel-body {
  font-size: 0.95rem;
  color: rgba(15, 14, 26, 0.65);
  line-height: 1.7;
  margin: 0 0 1.5rem;
}

.cs-panel-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary);
  text-decoration: none;
  transition: gap 200ms;
}

.cs-panel-link:hover {
  gap: 0.6rem;
}

@media (max-width: 500px) {
  .cs-panel {
    padding: 1.5rem;
  }

  .cs-tab {
    padding: 0.6rem 1rem;
  }
}
</style>
