---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';

const cases = await getCollection('portfolio');
cases.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Casos de Éxito — Tp3studio"
  description="Descubre cómo negocios reales están creciendo con su web y chatbot de Tp3studio."
>
  <section class="section">
    <div class="container">
      <div class="page-header">
        <span class="section-label">Casos de Éxito</span>
        <h1>Negocios reales, resultados reales</h1>
        <p>Cada uno de estos negocios dio el salto digital con Tp3studio.</p>
      </div>

      <div class="portfolio-grid">
        {cases.map(c => (
          <PortfolioCard
            name={c.data.name}
            location={c.data.location}
            description={c.data.description}
            tags={c.data.tags}
            href={`/portfolio/${c.id}`}
            url={c.data.url}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  text-align: center;
  max-width: 36rem;
  margin: 0 auto 3rem;
}
.page-header h1 { margin-bottom: 0.75rem; }
.page-header p { font-size: 1.0625rem; color: rgba(15, 14, 26, 0.6); }

.portfolio-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 640px) {
  .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 900px) {
  .portfolio-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
