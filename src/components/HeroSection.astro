---
export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const badgeText = lang === 'en'
  ? '+100 businesses in Colombia, Mexico, and DR already have it'
  : '+100 negocios en Colombia, México y RD ya la tienen';

const titleParts = lang === 'en'
  ? { before: 'Your business online, working on its own, in', highlight1: '48 hours', middle: '. From', highlight2: '$100 USD', after: '.' }
  : { before: 'Tu negocio en línea, atendiendo solo, en', highlight1: '48 horas', middle: '. Desde', highlight2: '$100 USD', after: '.' };

const subtitle = lang === 'en'
  ? 'Tell us about your business. In 48 hours we deliver a professional website with an integrated WhatsApp chatbot. From <strong>$100 USD</strong>. One time.'
  : 'Nos cuentas de tu negocio. En 48 horas te entregamos una web profesional con chatbot de WhatsApp incluido. Desde <strong>$100 USD</strong>. Una sola vez.';

const features = lang === 'en'
  ? ['Ready in 48h', '24/7 Chatbot', 'Perfect on mobile']
  : ['Lista en 48h', 'Chatbot 24/7', 'Perfecto en celular'];

const asesorText = lang === 'en' ? 'Personalized advice' : 'Asesoría personalizada';
const ctaPrimaryText = lang === 'en' ? 'I want my website' : 'Quiero mi página web';
const chatBotLabel = lang === 'en' ? 'Chatbot active now' : 'Chatbot activo ahora';
const chatBotGreeting = lang === 'en' ? 'Hello! How can I help you today?' : '¡Hola! ¿En qué puedo ayudarte hoy?';
const chatBotReply = lang === 'en' ? 'I want info about your services' : 'Quiero información sobre sus servicios';
const chatBotResponse = lang === 'en' ? 'Sure! What kind of business do you have?' : '¡Claro! ¿Qué tipo de negocio tienes?';
const chatHeader = 'Chatbot Tp3studio';
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        {badgeText}
      </div>
      <h1 class="hero-title">
        {titleParts.before} <span class="hero-highlight">{titleParts.highlight1}</span>{titleParts.middle} <span class="hero-highlight">{titleParts.highlight2}</span>{titleParts.after}
      </h1>
      <p class="hero-subtitle" set:html={subtitle}>
      </p>
      <div class="hero-actions">
        <a href={lang === 'en' ? '/en/precios' : '/precios'} class="btn-primary-hero">
          <span class="btn-primary-label">{ctaPrimaryText}</span>
          <span class="btn-primary-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="btn-shimmer" aria-hidden="true"></span>
        </a>
        <a href="https://wa.me/15559273372?text=Hola%2C%20quiero%20asesor%C3%ADa%20para%20elegir%20el%20plan%20ideal%20para%20mi%20negocio." class="btn-whatsapp-hero">
          <span class="btn-wa-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
          </span>
          {asesorText}
        </a>
      </div>
      <div class="hero-features">
        {features.map(f => (
          <div class="hero-feat">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {f}
          </div>
        ))}
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-phone">
        <div class="hero-phone-frame">
          <div class="hero-phone-notch"></div>
          <div class="hero-phone-screen">
            <div class="hp-nav"><div class="hp-logo"></div><div class="hp-menu"></div></div>
            <div class="hp-hero"><div class="hp-line"></div><div class="hp-line short"></div><div class="hp-btn"></div></div>
            <div class="hp-chat-window">
              <div class="hp-chat-header">{chatHeader}</div>
              <div class="hp-msg">{chatBotGreeting}</div>
              <div class="hp-msg reply">{chatBotReply}</div>
              <div class="hp-msg">{chatBotResponse}</div>
              <div class="hp-typing"><span></span><span></span><span></span></div>
            </div>
          </div>
        </div>
        <div class="hero-float-card">
          <span class="hf-dot"></span>
          {chatBotLabel}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero { position: relative; padding: 4rem 0 6rem; overflow: hidden; }

.hero-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.25; }
.blob-1 { width: 500px; height: 500px; background: radial-gradient(circle, #4F46E5 0%, transparent 70%); top: -200px; right: -150px; animation: float 8s ease-in-out infinite; }
.blob-2 { width: 350px; height: 350px; background: radial-gradient(circle, #6366F1 0%, transparent 70%); bottom: -100px; left: -100px; animation: float 10s ease-in-out infinite reverse; }
.blob-3 { width: 250px; height: 250px; background: radial-gradient(circle, #A5B4FC 0%, transparent 70%); top: 40%; left: 10%; animation: float 12s ease-in-out infinite 2s; }
.blob-4 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, transparent 70%); top: 30%; right: 20%; animation: float 9s ease-in-out infinite 1s; }
@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(20px, -20px) scale(1.05); }
  50% { transform: translate(-10px, 15px) scale(0.95); }
  75% { transform: translate(-20px, -10px) scale(1.02); }
}

.hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
.hero-content { max-width: 36rem; }

.hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-body); font-size: 0.8125rem; font-weight: 600; color: var(--color-clay); background: rgba(99, 102, 241, 0.07); padding: 0.45rem 1.1rem; border-radius: var(--radius-full); margin-bottom: 1.5rem; }
.hero-badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 6px rgba(34, 197, 94, 0.5); animation: pulse-dot 2s ease-in-out infinite; }
@keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

.hero-title { font-size: clamp(2.75rem, 7vw, 5rem); line-height: 1.08; margin-bottom: 1.25rem; color: var(--color-deep); }
.hero-highlight { position: relative; display: inline-block; }
.hero-highlight::after { content: ''; position: absolute; bottom: 2px; left: 0; right: 0; height: 0.35em; background: rgba(99, 102, 241, 0.2); border-radius: 2px; z-index: -1; }

.hero-subtitle { font-size: 1.15rem; color: rgba(15, 14, 26, 0.65); max-width: 30rem; margin-bottom: 2rem; line-height: 1.7; }

.hero-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-bottom: 2rem; }

/* Primary CTA */
.btn-primary-hero {
  position: relative;
  display: inline-flex; align-items: center; gap: 0.625rem;
  font-family: var(--font-body); font-weight: 800; font-size: 1.1rem;
  padding: 1.1rem 2.5rem;
  text-decoration: none; white-space: nowrap; cursor: pointer;
  border: none; border-radius: var(--radius-full);
  color: #fff;
  background: var(--color-deep);
  box-shadow: 0 6px 30px rgba(15, 14, 26, 0.3), 0 2px 6px rgba(0,0,0,0.1), inset 0 1px 0 rgba(255,255,255,0.1);
  overflow: hidden; isolation: isolate;
  transition: transform 300ms cubic-bezier(.34,1.56,.64,1), box-shadow 300ms ease;
}
.btn-primary-hero::before {
  content: ''; position: absolute; inset: 2px; border-radius: inherit;
  background: linear-gradient(135deg, #6366F1, #4F46E5, #4338CA);
  z-index: -1; transition: opacity 300ms;
}
.btn-primary-hero:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 12px 40px rgba(99, 102, 241, 0.4), 0 4px 12px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.15); }
.btn-primary-hero:active { transform: scale(0.97); transition: transform 100ms; }

.btn-shimmer {
  position: absolute; inset: 0; border-radius: inherit;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.12) 45%, rgba(255,255,255,0.25) 50%, rgba(255,255,255,0.12) 55%, transparent 60%);
  transform: translateX(-100%);
  animation: shimmer-sweep 3.5s ease-in-out infinite;
}
@keyframes shimmer-sweep { 0%, 100% { transform: translateX(-100%); } 50% { transform: translateX(100%); } }

.btn-primary-label { position: relative; z-index: 1; }

.btn-primary-icon { position: relative; z-index: 1; display: flex; align-items: center; transition: transform 300ms cubic-bezier(.34,1.56,.64,1); }
.btn-primary-hero:hover .btn-primary-icon { transform: translateX(5px); }

/* WhatsApp CTA */
.btn-whatsapp-hero {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-family: var(--font-body); font-weight: 700; font-size: 0.9375rem;
  padding: 0.95rem 1.75rem;
  text-decoration: none; white-space: nowrap; cursor: pointer;
  border-radius: var(--radius-full);
  color: var(--color-deep);
  background: transparent;
  border: 2px solid var(--color-border);
  transition: border-color 250ms, background 250ms, transform 250ms cubic-bezier(.34,1.56,.64,1), box-shadow 250ms;
}
.btn-whatsapp-hero:hover { border-color: #25D366; background: rgba(37, 211, 102, 0.06); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(37, 211, 102, 0.12); }
.btn-whatsapp-hero:active { transform: scale(0.97); }

.btn-wa-icon { display: flex; align-items: center; color: #25D366; transition: transform 300ms cubic-bezier(.34,1.56,.64,1); }
.btn-whatsapp-hero:hover .btn-wa-icon { transform: scale(1.15) rotate(-8deg); }

.hero-features { display: flex; flex-wrap: wrap; gap: 1.5rem; }
.hero-feat { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: rgba(15, 14, 26, 0.5); }
.hero-feat svg { color: var(--color-terracotta); }

/* Phone mockup */
.hero-visual { display: flex; justify-content: center; align-items: center; }
.hero-phone { position: relative; }
.hero-phone-frame { width: 260px; background: #fff; border-radius: 2.5rem; border: 3px solid var(--color-deep); overflow: hidden; box-shadow: var(--shadow-lg), 0 0 0 8px rgba(99, 102, 241, 0.08); }
.hero-phone-notch { width: 70px; height: 6px; background: var(--color-deep); border-radius: 3px; margin: 0.75rem auto 0; }
.hero-phone-screen { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; }
.hp-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; }
.hp-logo { width: 60px; height: 10px; background: var(--color-terracotta); border-radius: 5px; opacity: 0.5; }
.hp-menu { width: 18px; height: 12px; border-top: 2px solid var(--color-border); border-bottom: 2px solid var(--color-border); }
.hp-hero { display: flex; flex-direction: column; gap: 0.4rem; padding: 0.75rem 0; }
.hp-line { width: 100%; height: 8px; background: var(--color-deep); border-radius: 4px; opacity: 0.8; }
.hp-line.short { width: 65%; }
.hp-btn { width: 100px; height: 24px; background: var(--color-amber); border-radius: 12px; margin-top: 0.25rem; }
.hp-chat-window { background: var(--color-surface); border-radius: 1rem; padding: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; border: 1px solid var(--color-border); }
.hp-chat-header { font-size: 0.625rem; font-weight: 700; color: var(--color-terracotta); margin-bottom: 0.25rem; }
.hp-msg { font-size: 0.6rem; padding: 0.4rem 0.55rem; border-radius: 0.6rem 0.6rem 0.6rem 0.2rem; background: #fff; max-width: 82%; line-height: 1.4; }
.hp-msg.reply { align-self: flex-end; background: var(--color-terracotta); color: #fff; border-radius: 0.6rem 0.6rem 0.2rem 0.6rem; }
.hp-typing { display: flex; gap: 3px; padding: 0.25rem 0; }
.hp-typing span { width: 5px; height: 5px; border-radius: 50%; background: var(--color-border); animation: bounce 1.4s ease-in-out infinite; }
.hp-typing span:nth-child(2) { animation-delay: 0.2s; }
.hp-typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { 0%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-4px); } }

.hero-float-card {
  position: absolute; bottom: 20px; right: -40px;
  background: #fff; padding: 0.55rem 1rem;
  border-radius: var(--radius-full); box-shadow: var(--shadow-md);
  font-size: 0.75rem; font-weight: 600;
  display: flex; align-items: center; gap: 0.4rem; white-space: nowrap;
  animation: float-card 3s ease-in-out infinite;
}
.hero-float-card .hf-dot { width: 7px; height: 7px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 6px rgba(34, 197, 94, 0.5); }
@keyframes float-card { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }

@media (min-width: 768px) { .hero-inner { grid-template-columns: 1.15fr 0.85fr; } .hero { padding: 5rem 0 8rem; } }
@media (max-width: 480px) { .btn-primary-hero, .btn-whatsapp-hero { width: 100%; justify-content: center; } }
</style>
