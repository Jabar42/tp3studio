---
// Canonical BaseLayout following Astro docs pattern
// https://docs.astro.build/en/basics/astro-pages/
// Usage: <BaseLayout title="Page" description="..."><slot /></BaseLayout>

import SEOHead from './SEOHead.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <SEOHead {title} {description} {ogImage} />

    <!-- Global styles: scoped to :root, applies to entire site -->
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --color-primary: #6366F1;
        --color-bg: #FAFAFA;
        --color-fg: #18181B;
        --color-muted: #F4F4F5;
        --color-border: #E4E4E7;
        --font-sans: system-ui, sans-serif;
        --max-width: 1200px;
      }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--color-fg);
        background: var(--color-bg);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
