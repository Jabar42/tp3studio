---
export interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  href: string;
}

const { title, description, date, tags = [], href } = Astro.props;
---

<a href={href} class="blog-card">
  <div class="blog-card-body">
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-desc">{description}</p>
    <time class="blog-card-date" datetime={date}>{date}</time>
  </div>
</a>

<style>
.blog-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: border-color 200ms, box-shadow 200ms, transform 200ms;
}

.blog-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.blog-card-body {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.blog-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-bottom: 0.25rem;
}

.tag {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.2rem 0.55rem;
  border-radius: var(--radius-full);
  background: rgba(99, 102, 241, 0.08);
  color: var(--color-primary);
}

.blog-card-title {
  font-size: 1.125rem;
  font-weight: 700;
  line-height: 1.35;
  margin: 0;
}

.blog-card-desc {
  font-size: 0.875rem;
  color: rgba(15, 14, 26, 0.6);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.blog-card-date {
  font-size: 0.8125rem;
  color: rgba(15, 14, 26, 0.4);
  display: block;
}
</style>
