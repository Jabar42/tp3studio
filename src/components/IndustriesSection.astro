---
import type en from '../i18n/en';

export interface Props {
  t: typeof en.industries;
}

const { t } = Astro.props;
---

<section class="industries section" id="industrias">
  <div class="container">
    <div class="ind-header">
      <span class="section-label">{t.label}</span>
      <h2>{t.title} <span class="accent-text">{t.titleHighlight}</span></h2>
      <p class="ind-subtitle">{t.subtitle}</p>
    </div>
    <div class="ind-grid">
      {t.cards.map(card => (
        <div class="ind-card">
          <span class="ind-icon">{card.icon}</span>
          <h3>{card.name}</h3>
          <p>{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.industries {
  background: #fff;
}

.ind-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 3rem;
}

.ind-subtitle {
  font-size: 1.0625rem;
  color: rgba(15, 14, 26, 0.55);
  margin-top: 0.5rem;
  line-height: 1.6;
}

.ind-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  max-width: 1000px;
  margin: 0 auto;
}

.ind-card {
  background: #fff;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  transition: transform 200ms, box-shadow 200ms, border-color 200ms;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.5rem;
}

.ind-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: var(--color-sand);
}

.ind-icon {
  font-size: 2rem;
  margin-bottom: 0.25rem;
}

.ind-card h3 {
  font-family: 'Outfit', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-deep);
  margin: 0;
}

.ind-card p {
  font-size: 0.85rem;
  color: rgba(15, 14, 26, 0.55);
  line-height: 1.55;
  margin: 0;
}

@media (min-width: 500px) {
  .ind-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 850px) {
  .ind-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>
