---
import type en from '../i18n/en';

export interface Props {
  t: typeof en.howItWorks;
}

const { t } = Astro.props;
---

<section class="hiw section" id="como-funciona">
  <div class="container">
    <div class="hiw-header">
      <span class="section-label">{t.label}</span>
      <h2>{t.title} <span class="accent-text">{t.titleHighlight}</span></h2>
      <p>{t.subtitle}</p>
    </div>
    <div class="hiw-steps">
      <div class="hiw-step">
        <div class="hiw-step-number"><span>{t.step1.number}</span></div>
        <div class="hiw-step-card"><div class="hiw-step-icon">📝</div><h3>{t.step1.title}</h3><p>{t.step1.desc}</p></div>
      </div>
      <div class="hiw-connector"><div class="hiw-connector-line"></div></div>
      <div class="hiw-step">
        <div class="hiw-step-number"><span>{t.step2.number}</span></div>
        <div class="hiw-step-card"><div class="hiw-step-icon">🤖</div><h3>{t.step2.title}</h3><p>{t.step2.desc}</p></div>
      </div>
      <div class="hiw-connector"><div class="hiw-connector-line"></div></div>
      <div class="hiw-step">
        <div class="hiw-step-number"><span>{t.step3.number}</span></div>
        <div class="hiw-step-card"><div class="hiw-step-icon">💬</div><h3>{t.step3.title}</h3><p>{t.step3.desc}</p></div>
      </div>
      <div class="hiw-connector"><div class="hiw-connector-line"></div></div>
      <div class="hiw-step">
        <div class="hiw-step-number"><span>{t.step4.number}</span></div>
        <div class="hiw-step-card"><div class="hiw-step-icon">📈</div><h3>{t.step4.title}</h3><p>{t.step4.desc}</p></div>
      </div>
    </div>
    <div class="hiw-cta">
      <a href="#precios" class="btn-creative btn-primary btn-md">{t.cta} <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    </div>
  </div>
</section>

<style>
.hiw { background: #fff; }
.hiw-header { text-align: center; max-width: 34rem; margin: 0 auto 4rem; }
.hiw-header p { font-size: 1.0625rem; color: rgba(45,26,15,0.6); }
.hiw-steps { max-width: 40rem; margin: 0 auto; }
.hiw-step { display: flex; gap: 1.5rem; align-items: flex-start; }
.hiw-step-number { width: 4rem; height: 4rem; border-radius: 50%; background: var(--color-accent); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; flex-shrink: 0; box-shadow: 0 4px 16px rgba(217,119,6,0.2); }
.hiw-step-card { background: #fff; border: 1.5px solid var(--color-border); border-radius: var(--radius-xl); padding: 1.75rem; flex: 1; margin-bottom: 0.25rem; }
.hiw-step-icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
.hiw-step-card h3 { font-size: 1.25rem; margin-bottom: 0.35rem; }
.hiw-step-card p { font-size: 0.9375rem; color: rgba(45,26,15,0.6); margin: 0; }
.hiw-connector { padding: 0.5rem 0 0.5rem 2rem; }
.hiw-connector-line { width: 2px; height: 2rem; background: linear-gradient(180deg, var(--color-border), var(--color-terracotta), var(--color-border)); border-radius: 1px; }
.hiw-cta { text-align: center; margin-top: 3rem; }
</style>
