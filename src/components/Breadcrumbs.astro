---
/**
 * Breadcrumbs.astro
 *
 * Breadcrumb navigation estilo Linear/Vercel con paleta indigo/violet.
 * Schema.org BreadcrumbList incluido.
 *
 * Uso:
 *   <Breadcrumbs pathname={Astro.url.pathname} currentLabel={title} />
 *   <Breadcrumbs pathname={Astro.url.pathname} />
 *
 * La homepage (/) y 404 no muestran breadcrumbs.
 */

export interface Props {
  pathname: string;
  /** Label para la página actual (dinámica) — ej: título del artículo o caso */
  currentLabel?: string;
  /** Idioma */
  lang?: 'es' | 'en';
}

const { pathname, currentLabel, lang = 'es' } = Astro.props;

// Mapa de rutas estáticas → etiquetas
const routeLabels: Record<string, Record<string, string>> = {
  '/blog': { es: 'Blog', en: 'Blog' },
  '/portfolio': { es: 'Casos de Éxito', en: 'Case Studies' },
  '/precios': { es: 'Precios', en: 'Pricing' },
  '/audit': { es: 'Auditoría Gratis', en: 'Free Audit' },
  '/white-label': { es: 'White Label', en: 'White Label' },
  '/about': { es: 'Nuestra Historia', en: 'Our Story' },
  '/preview': { es: 'Prueba tu web', en: 'Preview your site' },
  '/auth': { es: 'Inicia Sesión', en: 'Sign In' },
  '/privacidad': { es: 'Privacidad', en: 'Privacy' },
  '/terminos': { es: 'Términos y Condiciones', en: 'Terms & Conditions' },
};

// Construir la lista de breadcrumbs
const segments = pathname.split('/').filter(Boolean);
const crumbs: { label: string; href?: string }[] = [];

if (segments.length > 0 && pathname !== '/' && pathname !== '/en') {
  // Siempre empezar con Inicio
  crumbs.push({ label: lang === 'en' ? 'Home' : 'Inicio', href: lang === 'en' ? '/en' : '/' });

  let accumulated = '';
  for (let i = 0; i < segments.length; i++) {
    const seg = segments[i];
    accumulated += '/' + seg;
    const isLast = i === segments.length - 1;

    if (!seg) continue;

    // Skip locale segment in path matching
    if (seg === 'en' && i === 0) continue;

    if (isLast && currentLabel) {
      crumbs.push({ label: currentLabel });
    } else if (routeLabels[accumulated]) {
      crumbs.push({
        label: routeLabels[accumulated][lang] || routeLabels[accumulated]['es'],
        href: isLast ? undefined : accumulated,
      });
    } else if (isLast && !currentLabel) {
      crumbs.push({ label: seg });
    }
  }
}

const itemListElement = crumbs.map((crumb, i) => ({
  '@type': 'ListItem' as const,
  position: i + 1,
  name: crumb.label,
  ...(crumb.href ? { item: new URL(crumb.href, 'https://tp3studio.com').href } : {}),
}));
---

{
  crumbs.length > 0 && (
    <>
      {/* Schema.org BreadcrumbList */}
      <script is:inline>
        {`{
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": ${JSON.stringify(itemListElement)}
        }`}
      </script>

      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs-list">
          {crumbs.map((crumb, i) => (
            <li class="breadcrumbs-item">
              {crumb.href ? (
                <a href={crumb.href} class="breadcrumbs-link">{crumb.label}</a>
              ) : (
                <span class="breadcrumbs-current" aria-current="page">{crumb.label}</span>
              )}
              {i < crumbs.length - 1 && (
                <span class="breadcrumbs-sep" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5.25 3.5L8.75 7L5.25 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </>
  )
}

<style>
  .breadcrumbs {
    padding: 1.25rem 0 0;
  }

  .breadcrumbs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.125rem;
  }

  .breadcrumbs-item {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    font-family: var(--font-body, 'Nunito', system-ui, sans-serif);
    font-size: 0.8125rem;
    line-height: 1;
  }

  .breadcrumbs-link {
    color: #71717A;
    text-decoration: none;
    font-weight: 500;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .breadcrumbs-link:hover {
    color: var(--color-primary, #6366F1);
    background: rgba(99, 102, 241, 0.08);
  }

  .breadcrumbs-link:active {
    background: rgba(99, 102, 241, 0.14);
    transform: scale(0.97);
  }

  .breadcrumbs-current {
    color: #18181B;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    background: rgba(99, 102, 241, 0.06);
    font-family: var(--font-heading, 'Outfit', system-ui, sans-serif);
    letter-spacing: -0.01em;
  }

  .breadcrumbs-sep {
    display: inline-flex;
    align-items: center;
    color: #A1A1AA;
    margin: 0 0.125rem;
    opacity: 0.6;
  }

  /* Responsive: en mobile más compacto */
  @media (max-width: 640px) {
    .breadcrumbs {
      padding: 0.75rem 0 0;
    }

    .breadcrumbs-link {
      font-size: 0.75rem;
      padding: 0.2rem 0.35rem;
    }

    .breadcrumbs-current {
      font-size: 0.75rem;
      padding: 0.2rem 0.35rem;
    }
  }
</style>
