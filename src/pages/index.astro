---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ComparisonSection from '../components/ComparisonSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import PricingCards from '../components/PricingCards.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTAFinalSection from '../components/CTAFinalSection.astro';
import { getTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": t.schema.businessName,
      "description": locale === 'en'
        ? "Professional websites with WhatsApp chatbot in 48 hours. From $100 USD."
        : "Páginas web profesionales con chatbot de WhatsApp en 48 horas. Desde $100 USD.",
      "url": "https://tp3studio.com",
      "telephone": "+155****3372",
      "email": "info@aitp3studio.com",
      "image": "https://tp3studio.com/og-image.jpg",
      "areaServed": ["Colombia", "México", "República Dominicana"],
      "priceRange": "$100-$200 USD",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": locale === 'en' ? 'Tp3studio Plans' : 'Planes Tp3studio',
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": locale === 'en' ? 'Modern Website' : 'Web Moderna' }, "price": "100", "priceCurrency": "USD" },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": locale === 'en' ? 'Website + AI Agent' : 'Web + Agente Virtual' }, "price": "150", "priceCurrency": "USD" },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": locale === 'en' ? 'Website + Agent + WhatsApp' : 'Web + Agente + WhatsApp Business' }, "price": "200", "priceCurrency": "USD" },
        ],
      },
    },
    {
      "@type": "FAQPage",
      "name": t.schema.faqLabel,
      "mainEntity": t.faq.items.map((item: { q: string; a: string }) => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a },
      })),
    },
  ],
};
---

<BaseLayout
  title={locale === 'en' ? t.siteTitle : t.siteTitle}
  description={locale === 'en'
    ? 'Professional website with WhatsApp chatbot. Ready in 48 hours from $100 USD. For businesses in Colombia, Mexico and DR.'
    : 'Páginas web profesionales con chatbot de WhatsApp en 48 horas desde $100 USD. Para negocios en Colombia, México y RD que quieren vender más sin complicarse.'}
  schema={JSON.stringify(schema)}
  locale={locale}
>
  <HeroSection lang={locale} />
  <ComparisonSection lang={locale} />
  <HowItWorks lang={locale} />
  <PricingCards lang={locale} />
  <TestimonialsSection lang={locale} />
  <FAQSection lang={locale} />
  <CTAFinalSection lang={locale} />
</BaseLayout>
