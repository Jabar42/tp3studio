---
import BaseLayout from '../layouts/BaseLayout.astro';
const cases = [
  { name: 'Restaurante El Buen Sabor', location: 'Medellín, Colombia', description: 'Web con menú digital y chatbot para reservas. 40% más reservas en el primer mes.', tags: ['Web + Agente', 'WhatsApp'] },
  { name: 'Consultorio Dental Sonrisas', location: 'CDMX, México', description: 'Sitio profesional con chatbot que agenda citas automáticamente. Reducción del 60% en llamadas.', tags: ['Web + Agente + Calendario'] },
  { name: 'Ferretería El Constructor', location: 'Santo Domingo, RD', description: 'Catálogo en línea con chatbot que cotiza materiales. Incremento del 25% en ventas.', tags: ['Web Moderna'] },
  { name: 'Abogados Asociados LM', location: 'Bogotá, Colombia', description: 'Web corporativa con agente IA que califica clientes potenciales. 50+ consultas calificadas al mes.', tags: ['Web + Agente', 'WhatsApp'] },
  { name: 'Tienda Moda Joven', location: 'Monterrey, México', description: 'E-commerce ligero con chatbot de atención 24/7. Ventas automatizadas desde el primer día.', tags: ['Web + Agente'] },
  { name: 'Clínica Veterinaria Patitas', location: 'Santiago, RD', description: 'Web con sistema de citas y recordatorios automáticos. 90% de clientes agenda en línea.', tags: ['Web + Agente + Calendario', 'WhatsApp'] },
];
---
<BaseLayout title="Casos de Éxito — Konversa" description="Descubre cómo negocios reales están creciendo con su web y chatbot de Konversa.">
  <section class="section"><div class="container">
    <div class="page-header"><span class="section-label">Casos de Éxito</span><h1>Negocios reales, resultados reales</h1><p>Cada uno de estos negocios dio el salto digital con Konversa.</p></div>
    <div class="portfolio-grid">
      {cases.map(c => (<article class="portfolio-card"><div class="portfolio-card-tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div><h3>{c.name}</h3><p class="portfolio-location">{c.location}</p><p class="portfolio-desc">{c.description}</p></article>))}
    </div>
  </div></section>
</BaseLayout>

<style>
.page-header { text-align: center; max-width: 36rem; margin: 0 auto 3rem; }
.page-header h1 { margin-bottom: 0.75rem; }
.page-header p { font-size: 1.0625rem; color: rgba(45,26,15,0.65); }
.portfolio-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
.portfolio-card { background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.75rem; transition: border-color 200ms, box-shadow 200ms; }
.portfolio-card:hover { border-color: var(--color-terracotta); box-shadow: var(--shadow-md); }
.portfolio-card-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
.tag { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; padding: 0.25rem 0.625rem; border-radius: var(--radius-full); background: rgba(217,119,6,0.08); color: var(--color-accent); }
.portfolio-card h3 { font-size: 1.125rem; margin-bottom: 0.25rem; }
.portfolio-location { font-size: 0.8125rem; color: rgba(45,26,15,0.45); margin-bottom: 0.75rem; }
.portfolio-desc { font-size: 0.875rem; color: rgba(45,26,15,0.7); margin: 0; }
@media (min-width: 640px) { .portfolio-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 900px) { .portfolio-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
