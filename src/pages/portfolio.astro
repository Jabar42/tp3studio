---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import { getTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);
const filterLocale = locale === 'en' ? 'en' : 'es';

const cases = await getCollection('portfolio', ({ data }) => data.locale === filterLocale || !data.locale);
cases.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={t.portfolio.title}
  description={t.portfolio.desc}
  locale={locale}
>
  <section class="section">
    <div class="container">
      <div class="page-header">
        <span class="section-label">{t.portfolio.label}</span>
        <h1>{locale === 'en' ? 'Real businesses, real results' : 'Negocios reales, resultados reales'}</h1>
        <p>{locale === 'en' ? 'Each of these businesses made the digital leap with Tp3studio.' : 'Cada uno de estos negocios dio el salto digital con Tp3studio.'}</p>
      </div>

      <div class="portfolio-grid">
        {cases.length === 0 && <p class="portfolio-empty">{t.portfolio.empty}</p>}
        {cases.map(c => (
          <PortfolioCard
            name={c.data.name}
            location={c.data.location}
            description={c.data.description}
            tags={c.data.tags}
            href={`/${locale === 'en' ? 'en/' : ''}portfolio/${c.id}`}
            url={c.data.url}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  text-align: center;
  max-width: 36rem;
  margin: 0 auto 3rem;
}
.page-header h1 { margin-bottom: 0.75rem; }
.page-header p { font-size: 1.0625rem; color: rgba(15, 14, 26, 0.6); }

.portfolio-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}
.portfolio-empty {
  text-align: center;
  color: rgba(15, 14, 26, 0.4);
  padding: 3rem 0;
}

@media (min-width: 640px) {
  .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 900px) {
  .portfolio-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
