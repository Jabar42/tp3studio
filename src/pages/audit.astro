---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Auditoría Gratis — Tp3studio" description="Recibe una auditoría gratuita de tu presencia digital.">
  <section class="section"><div class="container audit-inner">
    <div class="audit-header"><span class="section-label">Auditoría Gratis</span><h1>Descubre cómo está tu presencia digital</h1><p>Te decimos exactamente qué necesita tu negocio para vender más en línea. Sin compromiso.</p></div>
    <form class="audit-form">
      <div class="form-group"><label for="name">Nombre completo</label><input type="text" id="name" name="name" required placeholder="Tu nombre" /></div>
      <div class="form-group"><label for="business">Nombre de tu negocio</label><input type="text" id="business" name="business" required placeholder="Ej: Ferretería El Constructor" /></div>
      <div class="form-group"><label for="email">Correo electrónico</label><input type="email" id="email" name="email" required placeholder="tu@email.com" /></div>
      <div class="form-group"><label for="phone">WhatsApp (opcional)</label><input type="tel" id="phone" name="phone" placeholder="+57 300 000 0000" /></div>
      <div class="form-group"><label for="type">Tipo de negocio</label><select id="type" name="type" required><option value="">Selecciona una opción</option><option value="restaurante">Restaurante</option><option value="tienda">Tienda / Retail</option><option value="servicios">Servicios profesionales</option><option value="salud">Salud</option><option value="otro">Otro</option></select></div>
      <div class="form-group"><label for="message">Cuéntanos de tu negocio</label><textarea id="message" name="message" rows="4" placeholder="¿Tienes web? ¿Qué necesitas?"></textarea></div>
      <button type="submit" class="btn-creative btn-primary btn-lg form-submit">Solicitar auditoría gratis &rarr;</button>
      <p class="form-disclaimer">Te contactaremos en menos de 24h. Sin spam, sin compromiso.</p>
    </form>
  </div></section>
</BaseLayout>

<style>
.audit-inner { max-width: 36rem; }
.audit-header { text-align: center; margin-bottom: 2.5rem; }
.audit-header p { font-size: 1.0625rem; color: rgba(45,26,15,0.65); }
.audit-form { background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
.form-group { display: flex; flex-direction: column; gap: 0.375rem; }
.form-group label { font-size: 0.875rem; font-weight: 600; }
.form-group input, .form-group select, .form-group textarea { font-family: var(--font-body); font-size: 0.9375rem; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-bg); transition: border-color 200ms; min-height: 44px; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--color-terracotta); box-shadow: 0 0 0 3px rgba(198,123,92,0.1); }
.form-submit { width: 100%; margin-top: 0.5rem; }
.form-disclaimer { text-align: center; font-size: 0.8125rem; color: rgba(45,26,15,0.45); margin: 0; }
</style>
