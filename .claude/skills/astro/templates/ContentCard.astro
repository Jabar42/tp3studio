---
// Canonical content card component following Astro docs pattern
// https://docs.astro.build/en/basics/astro-components/#component-props
// Usage: <ContentCard title="Post Title" description="..." href="/post/1" />

export interface Props {
  title: string;
  description?: string;
  image?: { src: string; alt: string };
  href?: string;
  tags?: string[];
  date?: Date;
}

const { title, description, image, href, tags = [], date } = Astro.props;
const CardTag = href ? 'a' : 'article';
---

<CardTag {href} class:list={['card', { 'card--linked': href }]}>
  {image && (
    <div class="card-image">
      <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
    </div>
  )}

  <div class="card-body">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => <span class="card-tag">{tag}</span>)}
      </div>
    )}

    <h3 class="card-title">{title}</h3>

    {description && <p class="card-desc">{description}</p>}

    {date && (
      <time class="card-date" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    )}
  </div>
</CardTag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 200ms, box-shadow 200ms;
  }

  .card--linked {
    text-decoration: none;
    color: inherit;
  }

  .card--linked:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .card-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: rgba(99,102,241,0.08);
    color: var(--color-primary);
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .card-desc {
    font-size: 0.875rem;
    color: #71717A;
    line-height: 1.6;
    margin: 0;
  }

  .card-date {
    font-size: 0.75rem;
    color: #A1A1AA;
  }
</style>
