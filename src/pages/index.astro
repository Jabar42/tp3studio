---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import WhatIsTp3Section from '../components/WhatIsTp3Section.astro';
import StatsBar from '../components/StatsBar.astro';
import ChatToAdminSection from '../components/ChatToAdminSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import IndustriesSection from '../components/IndustriesSection.astro';
import CaseStudiesSection from '../components/CaseStudiesSection.astro';
import PricingCards from '../components/PricingCards.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTAFinalSection from '../components/CTAFinalSection.astro';
import { getTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);

const faqEntities = t.faq.items.map((item: { q: string; a: string }) => ({
  "@type": "Question",
  "name": item.q,
  "acceptedAnswer": { "@type": "Answer", "text": item.a },
}));

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Tp3studio",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": t.schema.businessDesc,
      "url": "https://tp3studio.com",
      "image": "https://tp3studio.com/og-image.jpg",
      "areaServed": ["Colombia", "Mexico", "Dominican Republic"],
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "USD",
        "lowPrice": "49",
        "highPrice": "199",
        "offerCount": "3",
        "offers": [
          {
            "@type": "Offer",
            "name": locale === 'en' ? 'Start' : 'Inicio',
            "price": "49",
            "priceCurrency": "USD",
            "description": locale === 'en' ? 'AI-operated website with chat-to-admin' : 'Sitio web operado por IA con chat-to-admin',
          },
          {
            "@type": "Offer",
            "name": locale === 'en' ? 'Growth' : 'Crecer',
            "price": "99",
            "priceCurrency": "USD",
            "description": locale === 'en' ? 'AI-operated business with e-commerce' : 'Negocio digital operado por IA con e-commerce',
          },
          {
            "@type": "Offer",
            "name": locale === 'en' ? 'Scale' : 'Escalar',
            "price": "199",
            "priceCurrency": "USD",
            "description": locale === 'en' ? 'AI-operated digital business with 24/7 AI agent' : 'Negocio digital operado por IA con agente 24/7',
          },
        ],
      },
    },
    {
      "@type": "FAQPage",
      "name": t.schema.faqLabel,
      "mainEntity": faqEntities,
    },
  ],
};
---

<BaseLayout
  title={locale === 'en' ? t.siteTitle : t.siteTitle}
  description={t.siteDesc}
  schema={JSON.stringify(schema)}
  locale={locale}
>
  <HeroSection t={t.hero} />
  <WhatIsTp3Section t={t.whatIsTp3} />
  <StatsBar t={t.statsBar} />
  <ChatToAdminSection t={t.chatToAdmin} />
  <IndustriesSection t={t.industries} />
  <CaseStudiesSection t={t.caseStudies} />
  <HowItWorks t={t.howItWorks} />
  <PricingCards t={t.pricing} />
  <TestimonialsSection t={t.testimonials} />
  <FAQSection t={t.faq} />
  <CTAFinalSection t={t.ctaFinal} />
</BaseLayout>
