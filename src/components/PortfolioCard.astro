---
export interface Props {
  name: string;
  location: string;
  description: string;
  tags?: string[];
  image?: string;
  href?: string;
  url?: string;
}

const { name, location, description, tags = [], image, href, url } = Astro.props;
const Element = href ? 'a' : 'article';
---

<Element {href} class:list={['card', { 'card--linked': href }]}>
  {url && (
    <div class="card-preview">
      <iframe src={url} title={name} loading="lazy" sandbox="allow-scripts allow-same-origin" class="card-iframe"></iframe>
      <div class="card-preview-overlay" aria-hidden="true"></div>
    </div>
  )}

  {!url && image && (
    <div class="card-image">
      <img src={image} alt={name} loading="lazy" decoding="async" />
    </div>
  )}

  <div class="card-body">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}

    <h3 class="card-title">{name}</h3>
    <p class="card-location">{location}</p>
    <p class="card-desc">{description}</p>
  </div>
</Element>

<style>
.card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color 200ms, box-shadow 200ms, transform 200ms;
}

.card--linked {
  text-decoration: none;
  color: inherit;
}

.card--linked:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.card-image img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.card-preview {
  position: relative;
  height: 220px;
  overflow: hidden;
  background: var(--color-muted);
}

.card-iframe {
  width: 200%;
  height: 200%;
  border: none;
  transform: scale(0.5);
  transform-origin: top left;
  pointer-events: none;
}

.card-preview-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.card-body {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-bottom: 0.25rem;
}

.tag {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-full);
  background: rgba(99, 102, 241, 0.08);
  color: var(--color-primary);
}

.card-title {
  font-size: 1.125rem;
  font-weight: 700;
  margin: 0;
  line-height: 1.3;
}

.card-location {
  font-size: 0.8125rem;
  color: rgba(15, 14, 26, 0.4);
  margin: 0;
}

.card-desc {
  font-size: 0.875rem;
  color: rgba(15, 14, 26, 0.65);
  line-height: 1.6;
  margin: 0;
}
</style>
