---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "Stack White Label Tp3studio",
      "description": "Stack completo de landing page moderna + agente IA de servicio al cliente + sistema de pago integrado para revender bajo tu propia marca.",
      "brand": { "@type": "Brand", "name": "Tp3studio" },
      "offers": [
        { "@type": "Offer", "name": "Starter", "price": "299", "priceCurrency": "USD", "description": "Web + chatbot IA. Perfecto para empezar." },
        { "@type": "Offer", "name": "Professional", "price": "499", "priceCurrency": "USD", "description": "Web, chatbot + pagos integrados. Sin comisiones recurrentes." },
        { "@type": "Offer", "name": "Enterprise", "price": "999", "priceCurrency": "USD", "description": "Stack completo con comisiones compartidas y dashboard multi-cliente." }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "¿Cómo funciona el white label?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nosotros construimos y operamos la tecnología. Tú le pones tu marca, cobras lo que quieras y te quedas con la diferencia." } },
        { "@type": "Question", "name": "¿Qué incluye exactamente?",
          "acceptedAnswer": { "@type": "Answer", "text": "Una landing page moderna con diseño responsive, un agente IA que atiende clientes 24/7 por WhatsApp, y un sistema de pagos integrados. Todo bajo tu propia marca." } },
        { "@type": "Question", "name": "¿Mis clientes sabrán que es suyo?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Todo se entrega con tu logo, tus colores, tu dominio, tu WhatsApp y tu información de contacto. Para ellos, eres tú quien lo hizo." } },
        { "@type": "Question", "name": "¿Necesito saber de tecnología?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Tú solo vendes y coordinas con tu cliente. Nosotros nos encargamos del desarrollo, hosting, chatbot y pagos." } },
        { "@type": "Question", "name": "¿Cuánto tarda la entrega?",
          "acceptedAnswer": { "@type": "Answer", "text": "De 48 a 72 horas desde que recibimos la información del cliente final y tu marca." } },
        { "@type": "Question", "name": "¿Puedo personalizar más allá de la marca?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. En los planes Professional y Enterprise puedes solicitar funcionalidades extra. Las cotizamos por separado." } }
      ]
    }
  ]
});
---

<BaseLayout
  title="White Label — Revende nuestro stack de IA con tu propia marca | Tp3studio"
  description="Revende landing pages modernas + agente IA de servicio al cliente + pagos integrados bajo tu propia marca. Entregamos todo listo en 48 horas. Sin que nadie sepa que es nuestro."
  schema={schema}
>
  <!-- HERO -->
  <section class="wl-hero">
    <div class="wl-hero-bg" aria-hidden="true">
      <div class="wl-blob wl-blob-1"></div>
      <div class="wl-blob wl-blob-2"></div>
      <div class="wl-blob wl-blob-3"></div>
    </div>
    <div class="container wl-hero-inner">
      <div class="wl-hero-content">
        <div class="wl-badge">🤝 White Label Partner</div>
        <h1 class="wl-hero-title">
          Revende nuestro stack de IA<br />
          <span class="wl-hero-highlight">como si fuera tuyo</span>
        </h1>
        <p class="wl-hero-subtitle">
          Entregamos landing pages modernas + agente IA que atiende 24/7 + pagos integrados.
          Tú pones tu marca, cobras lo que quieras.<br />
          <strong>Nadie sabe que es nuestro.</strong>
        </p>
        <div class="wl-hero-actions">
          <a href="#wl-form" class="wl-btn-primary">
            <span>Quiero ser partner</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://wa.me/15559273372?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20el%20programa%20White%20Label%20para%20revender%20su%20stack%20de%20IA." class="wl-btn-outline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
            Hablemos por WhatsApp
          </a>
        </div>
      </div>
      <div class="wl-hero-stats">
        <div class="wl-stat"><span class="wl-stat-num">48h</span><span class="wl-stat-label">entrega promedio</span></div>
        <div class="wl-stat"><span class="wl-stat-num">100%</span><span class="wl-stat-label">personalizable</span></div>
        <div class="wl-stat"><span class="wl-stat-num">0</span><span class="wl-stat-label">conocimiento técnico necesario</span></div>
      </div>
    </div>
  </section>

  <!-- PROBLEM / PAIN -->
  <section class="wl-pain section">
    <div class="container">
      <div class="wl-pain-header">
        <span class="section-label">El dilema</span>
        <h2>Te sobran clientes,<br /><span class="accent-text">te falta tiempo</span></h2>
        <p>Sabes que tus clientes necesitan web + IA para no quedarse atrás. Pero no puedes construir todo desde cero para cada uno. El resultado: clientes que se van a otro lado o proyectos que nunca terminan.</p>
      </div>
      <div class="wl-pain-grid">
        <div class="wl-pain-card">
          <span class="wl-pain-emoji">😤</span>
          <h3>Desarrollar desde cero es lento</h3>
          <p>Cada cliente implica diseñar, programar, testear y desplegar. Meses de trabajo por un ingreso que no justifica el esfuerzo.</p>
        </div>
        <div class="wl-pain-card">
          <span class="wl-pain-emoji">🔧</span>
          <h3>Mantener tecnología da pereza</h3>
          <p>Hosting, dominios, actualizaciones, seguridad. Te conviertes en soporte técnico 24/7 en vez de crecer tu negocio.</p>
        </div>
        <div class="wl-pain-card">
          <span class="wl-pain-emoji">💸</span>
          <h3>Cobrar barato no es negocio</h3>
          <p>Si no puedes entregar rápido y con calidad, terminas compitiendo por precio. Y a $50 USD una página web no vives de eso.</p>
        </div>
        <div class="wl-pain-card">
          <span class="wl-pain-emoji">🤖</span>
          <h3>La IA llegó y no sabes por dónde</h3>
          <p>Todos piden chatbot, automatización, pagos. Pero integrar todo bien requiere tiempo y expertise que quizás no tienes hoy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTION: WHAT THEY GET -->
  <section class="wl-stack section">
    <div class="container">
      <div class="wl-stack-header">
        <span class="section-label">Tu arsenal white label</span>
        <h2>El stack completo que entregamos<br /><span class="accent-text">bajo tu marca</span></h2>
      </div>
      <div class="wl-stack-grid">
        <article class="wl-stack-card">
          <div class="wl-stack-icon wl-stack-icon--web">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 10 10 0 0 0-10-10Z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z"/></svg>
          </div>
          <h3>Landing page moderna</h3>
          <p>Diseño responsive, ultra rápida, optimizada para SEO y conversión. Con tu logo, tus colores y tu dominio.</p>
        </article>
        <article class="wl-stack-card">
          <div class="wl-stack-icon wl-stack-icon--ai">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4Z"/><path d="M16 14H8a4 4 0 0 0-4 4v2h16v-2a4 4 0 0 0-4-4Z"/><circle cx="9" cy="9" r="1"/><circle cx="15" cy="9" r="1"/><path d="M9 17v3"/><path d="M15 17v3"/></svg>
          </div>
          <h3>Agente IA de servicio al cliente</h3>
          <p>Chatbot con WhatsApp que atiende preguntas, agenda citas y califica leads 24/7. Configurado para el negocio de tu cliente.</p>
        </article>
        <article class="wl-stack-card">
          <div class="wl-stack-icon wl-stack-icon--pay">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/><path d="M7 15h.01"/><path d="M11 15h2"/></svg>
          </div>
          <h3>Sistema de pagos integrado</h3>
          <p>Pasarela de pago lista para que los clientes compren, reserven o paguen servicios desde la web. Sin complicaciones.</p>
        </article>
        <article class="wl-stack-card">
          <div class="wl-stack-icon wl-stack-icon--brand">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2"/></svg>
          </div>
          <h3>Marca invisible</h3>
          <p>No hay rastro de Tp3studio en ningún lado. Sin créditos, sin logos ocultos, sin menciones. Es 100% tuyo.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="wl-how section">
    <div class="container">
      <div class="wl-how-header">
        <span class="section-label">Cómo funciona</span>
        <h2>Tan simple que parece <span class="accent-text">invento</span></h2>
      </div>
      <div class="wl-how-steps">
        <div class="wl-how-step">
          <div class="wl-num">1</div>
          <div class="wl-how-card">
            <div class="wl-how-card-icon">🤝</div>
            <h3>Tú vendes a tu cliente</h3>
            <p>Le ofreces web + chatbot + pagos como servicio tuyo. Cobras lo que quieras — $200, $500, $1000 USD. Tú pones el precio.</p>
          </div>
        </div>
        <div class="wl-how-step">
          <div class="wl-num">2</div>
          <div class="wl-how-card">
            <div class="wl-how-card-icon">📋</div>
            <h3>Nos pasas los datos</h3>
            <p>Compartes la info del cliente final (negocio, colores, logo, contenido, WhatsApp) y nos dices tu marca para personalizar todo.</p>
          </div>
        </div>
        <div class="wl-how-step">
          <div class="wl-num">3</div>
          <div class="wl-how-card">
            <div class="wl-how-card-icon">⚡</div>
            <h3>Entregamos en 48h</h3>
            <p>Desplegamos landing page, agente IA y pagos bajo <strong>tu marca</strong>. Tú recibes el enlace y se lo envías a tu cliente.</p>
          </div>
        </div>
        <div class="wl-how-step">
          <div class="wl-num">4</div>
          <div class="wl-how-card">
            <div class="wl-how-card-icon">💰</div>
            <h3>Tú cobras, nosotros operamos</h3>
            <p>El cliente te paga a ti. Nosotros nos encargamos del hosting, chatbot y mantenimiento. Tú solo repites.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="wl-plans section" id="planes">
    <div class="container">
      <div class="wl-plans-header">
        <span class="section-label">Planes white label</span>
        <h2>Elige cómo revender <span class="accent-text">nuestro stack</span></h2>
      </div>
      <div class="wl-plans-grid">
        <article class="wl-plan wl-plan--starter">
          <h3 class="wl-plan-name">Starter</h3>
          <div class="wl-plan-price"><span class="wl-plan-amount">$299</span> <span class="wl-plan-dur">USD por cliente</span></div>
          <p class="wl-plan-desc">Para empezar a revender sin complicaciones.</p>
          <ul class="wl-plan-feats">
            <li>Landing page moderna</li>
            <li>Agente IA WhatsApp</li>
            <li>Hosting 1 año incluido</li>
            <li>Marca blanca completa</li>
            <li>Sin comisiones recurrentes</li>
          </ul>
          <a href="#wl-form" class="wl-btn-block wl-btn-block--primary">Elegir Starter</a>
        </article>
        <article class="wl-plan wl-plan--professional">
          <div class="wl-plan-popular">Más popular</div>
          <h3 class="wl-plan-name">Professional</h3>
          <div class="wl-plan-price"><span class="wl-plan-amount">$499</span> <span class="wl-plan-dur">USD por cliente</span></div>
          <p class="wl-plan-desc">Lo que tu cliente espera: web, IA y pagos.</p>
          <ul class="wl-plan-feats">
            <li>Todo lo de Starter</li>
            <li>Sistema de pagos integrado</li>
            <li>Panel simple de administración</li>
            <li>Soporte prioritario 24/7</li>
            <li>Sin comisiones recurrentes</li>
          </ul>
          <a href="#wl-form" class="wl-btn-block wl-btn-block--primary">Elegir Professional</a>
        </article>
        <article class="wl-plan wl-plan--enterprise">
          <h3 class="wl-plan-name">Enterprise</h3>
          <div class="wl-plan-price"><span class="wl-plan-amount">$999</span> <span class="wl-plan-dur">USD por cliente</span></div>
          <p class="wl-plan-desc">Para agencias que revenden en volumen.</p>
          <ul class="wl-plan-feats">
            <li>Todo lo de Professional</li>
            <li>Comisiones compartidas (30%)</li>
            <li>Dashboard multi-cliente</li>
            <li>Funcionalidades a medida</li>
            <li>API de integración</li>
          </ul>
          <a href="#wl-form" class="wl-btn-block wl-btn-block--primary">Elegir Enterprise</a>
        </article>
      </div>
      <p class="wl-plans-note">* Pagas solo cuando tu cliente paga. Sin cuotas mensuales, sin membresías, sin riesgos.</p>
    </div>
  </section>

  <!-- WHY NOW -->
  <section class="wl-why section">
    <div class="container">
      <div class="wl-why-inner">
        <span class="section-label" style="color: rgba(255,255,255,0.7)">El momento</span>
        <h2>La IA en los negocios no es el futuro.<br /><span style="color: #A5B4FC">Es ahora.</span></h2>
        <p>El 67% de las pequeñas empresas en Latinoamérica aún no tienen presencia digital profesional. Las que ya tienen web están buscando cómo agregar IA. Hay una ventana de 12 a 18 meses para posicionarte como el referente en tu ciudad o nicho. Después, el mercado se satura.</p>
        <div class="wl-why-stats">
          <div class="wl-why-stat"><strong>67%</strong> <span>de negocios sin web profesional</span></div>
          <div class="wl-why-stat"><strong>3x</strong> <span>más leads con chatbot IA</span></div>
          <div class="wl-why-stat"><strong>48h</strong> <span>de entrega vs. meses</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="wl-faq section">
    <div class="container">
      <div class="wl-faq-header">
        <span class="section-label">FAQ</span>
        <h2>Todo lo que necesitas saber <span class="accent-text">antes de empezar</span></h2>
      </div>
      <div class="wl-faq-list">
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Cómo funciona el white label exactamente?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>Nosotros desarrollamos y operamos toda la tecnología — landing page, chatbot IA, pagos. Tú le pones tu marca, vendes a tu precio y te quedas con la diferencia. Nosotros nos encargamos del hosting, mantenimiento y soporte técnico. Para tu cliente, todo es tuyo.</p></div>
        </details>
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Mis clientes sabrán que Tp3studio está detrás?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>No. Todo se entrega con tu logo, tus colores, tu dominio, tu WhatsApp, tu email. No hay créditos, logos ocultos ni menciones a Tp3studio en ningún lado. Es 100% marca blanca.</p></div>
        </details>
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Necesito saber programar o de tecnología?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>No. Tú solo necesitas venderle a tu cliente y pasarnos la información básica: nombre del negocio, logo, colores, contenido, número de WhatsApp. Nosotros hacemos todo lo técnico.</p></div>
        </details>
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Hay costos mensuales o membresías?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>No. Pagas por cliente, una sola vez. El primer año de hosting va incluido. Después, el cliente renueva hosting directo con nosotros ($15 USD/año) o lo puede mover a donde quiera. Tú no pagas nada recurrente.</p></div>
        </details>
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Cuánto tarda la entrega?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>De 48 a 72 horas desde que recibimos toda la información del cliente final y tu marca. La mayoría de proyectos están listos en menos de 48h.</p></div>
        </details>
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Qué pasa si mi cliente quiere cambios después?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>Los primeros ajustes post-entrega están incluidos (textos, imágenes, colores). Cambios más grandes o funcionalidades nuevas se cotizan. Tú decides si los cobras o los incluyes en tu precio.</p></div>
        </details>
        <details class="wl-faq-item" name="wlfaq">
          <summary>¿Hay límite de clientes que puedo vender?<svg class="wl-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="wl-faq-answer"><p>No. Puedes vender a todos los clientes que quieras. Mientras más vendes, más opciones de descuento por volumen tenemos para ti.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- FORM / CTA -->
  <section class="wl-form-section" id="wl-form">
    <div class="wl-form-bg" aria-hidden="true">
      <div class="wl-form-blob wl-form-blob-1"></div>
      <div class="wl-form-blob wl-form-blob-2"></div>
    </div>
    <div class="container wl-form-inner">
      <div class="wl-form-content">
        <span class="section-label" style="color:rgba(255,255,255,0.7)">Empieza hoy</span>
        <h2>¿Listo para revender<br />sin construir nada?</h2>
        <p>Cuéntanos de ti y en menos de 24h te enviamos los detalles del partner pack: condiciones, tiempos y próximos pasos para que empieces a vender.</p>
        <div class="wl-form-benefits">
          <span>✅ Sin compromiso</span>
          <span>✅ Respuesta en 24h</span>
          <span>✅ Sin costo de entrada</span>
        </div>
      </div>
      <form class="wl-form" method="POST" action="/api/lead" data-wl-form>
        <input type="hidden" name="source" value="white-label" />
        <div class="wl-form-field">
          <label for="wl-name">Tu nombre</label>
          <input type="text" id="wl-name" name="name" required placeholder="Ej: Carlos Mendoza" />
        </div>
        <div class="wl-form-field">
          <label for="wl-email">Tu correo</label>
          <input type="email" id="wl-email" name="email" required placeholder="Ej: carlos@agenciadigital.com" />
        </div>
        <div class="wl-form-field">
          <label for="wl-company">Nombre de tu empresa o agencia</label>
          <input type="text" id="wl-company" name="company" required placeholder="Ej: Agencia Digital MX" />
        </div>
        <div class="wl-form-field">
          <label for="wl-plan">Plan que te interesa</label>
          <select id="wl-plan" name="plan" required>
            <option value="">Selecciona un plan</option>
            <option value="starter">Starter — $299 USD</option>
            <option value="professional">Professional — $499 USD</option>
            <option value="enterprise">Enterprise — $999 USD</option>
            <option value="not-sure">Aún no sé, quiero info</option>
          </select>
        </div>
        <div class="wl-form-field">
          <label for="wl-message">¿Cuántos clientes planeas vender al mes?</label>
          <select id="wl-message" name="message">
            <option value="1-3">1-3 clientes</option>
            <option value="4-10">4-10 clientes</option>
            <option value="10+">10+ clientes</option>
            <option value="not-sure">Aún no sé</option>
          </select>
        </div>
        <button type="submit" class="wl-btn-submit">
          Enviar solicitud
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <p class="wl-form-footnote">No compartiremos tus datos. Al enviar aceptas que te contactemos para darte más información.</p>
      </form>
    </div>
  </section>

  <script>
    // Handle form submission: submit via fetch, show success/error without page reload
    const form = document.querySelector('[data-wl-form]');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('.wl-btn-submit');
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Enviando...';

        try {
          const body = {};
          const fd = new FormData(form);
          for (const [key, val] of fd) body[key] = val;

          const res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });

          if (res.ok) {
            form.innerHTML = `
              <div class="wl-form-success">
                <span class="wl-success-icon">✅</span>
                <h3>¡Recibimos tu solicitud!</h3>
                <p>Te contactaremos en menos de 24h con el partner pack completo y los próximos pasos.</p>
                <p style="font-size:0.875rem;opacity:0.7">Mientras tanto, si tienes una urgencia, escríbenos directo a <a href="https://wa.me/15559273372" style="color:#A5B4FC;text-decoration:underline">WhatsApp</a>.</p>
              </div>
            `;
          } else {
            btn.disabled = false;
            btn.innerHTML = originalText;
            alert('Ocurrió un error. Intenta de nuevo o escríbenos por WhatsApp.');
          }
        } catch {
          btn.disabled = false;
          btn.innerHTML = originalText;
          alert('Error de conexión. Intenta de nuevo o escríbenos por WhatsApp.');
        }
      });
    }
  </script>
