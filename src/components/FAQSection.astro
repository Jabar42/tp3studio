---
import type en from '../i18n/en';

export interface Props {
  t: typeof en.faq;
}

const { t } = Astro.props;
---

<section class="faq section" id="faq">
  <div class="faq-inner container">
    <div class="faq-header">
      <span class="section-label">{t.label}</span>
      <h2>{t.title} <span class="accent-text">{t.titleHighlight}</span></h2>
    </div>
    <div class="faq-list">
      {t.items.map(item => (
        <details class="faq-item" name="faq">
          <summary>{item.q}<svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
          <div class="faq-answer"><p>{item.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
.faq-inner { max-width: 44rem; }
.faq { background: var(--color-cream); }
.faq-header { text-align: center; max-width: 34rem; margin: 0 auto 3rem; }
.faq-list { display: flex; flex-direction: column; gap: 0.625rem; }
.faq-item { background: #fff; border: 1.5px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: border-color 200ms, box-shadow 200ms; }
.faq-item:hover { border-color: var(--color-sand); }
.faq-item[open] { border-color: var(--color-terracotta); box-shadow: 0 0 0 4px rgba(198,123,92,0.06); }
.faq-item summary { padding: 1.25rem 1.5rem; font-weight: 700; font-size: 0.9375rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; list-style: none; transition: color 200ms; }
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item[open] summary { color: var(--color-clay); }
.faq-chevron { flex-shrink: 0; transition: transform 300ms cubic-bezier(.34,1.56,.64,1); color: var(--color-terracotta); }
.faq-item[open] .faq-chevron { transform: rotate(180deg); }
.faq-answer { padding: 0 1.5rem 1.25rem; }
.faq-answer p { margin: 0; font-size: 0.9rem; color: rgba(45,26,15,0.65); line-height: 1.7; }
</style>
