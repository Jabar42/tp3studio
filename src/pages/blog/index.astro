---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getTranslations } from '../../i18n';

const locale = Astro.currentLocale ?? 'es';
const t = getTranslations(locale);
const filterLocale = locale === 'en' ? 'en' : 'es';

const posts = await getCollection('blog', ({ data }) => data.draft !== true && (data.locale === filterLocale || !data.locale));
posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const dateLocale = locale === 'en' ? 'en-US' : 'es-CO';
---

<BaseLayout
  title={t.blog.title}
  description={t.blog.desc}
  locale={locale}
>
  <section class="section">
    <div class="container">
      <div class="blog-header">
        <span class="section-label">{t.blog.label}</span>
        <h1>{locale === 'en' ? 'Ideas to grow your business' : 'Ideas para hacer crecer tu negocio'}</h1>
        <p>{locale === 'en' ? 'Automation, chatbots, websites — everything a small business needs to sell more without the hassle.' : 'Automatización, chatbots, páginas web y todo lo que un pequeño negocio necesita para vender más sin complicarse.'}</p>
      </div>

      <div class="blog-grid">
        {posts.length === 0 && <p class="blog-empty">{t.blog.empty}</p>}
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.publishedAt.toLocaleDateString(dateLocale, { day: 'numeric', month: 'long', year: 'numeric' })}
            tags={post.data.tags}
            href={`/${locale === 'en' ? 'en/' : ''}blog/${post.id}`}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.blog-header {
  text-align: center;
  max-width: 36rem;
  margin: 0 auto 3rem;
}
.blog-header h1 { margin-bottom: 0.75rem; }
.blog-header p { font-size: 1.0625rem; color: rgba(15, 14, 26, 0.6); }

.blog-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}
.blog-empty {
  text-align: center;
  color: rgba(15, 14, 26, 0.4);
  padding: 3rem 0;
}

@media (min-width: 640px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 900px) {
  .blog-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
