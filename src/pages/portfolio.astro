---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const cases = await getCollection('portfolio');
cases.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Casos de Éxito — Tp3studio"
  description="Descubre cómo negocios reales están creciendo con su web y chatbot de Tp3studio."
>
  <section class="section">
    <div class="container">
      <div class="page-header">
        <span class="section-label">Casos de Éxito</span>
        <h1>Negocios reales, resultados reales</h1>
        <p>Cada uno de estos negocios dio el salto digital con Tp3studio.</p>
      </div>

      <div class="portfolio-grid">
        {cases.map(c => (
          <article class="portfolio-card">
            <div class="portfolio-card-tags">
              {c.data.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <h3>{c.data.name}</h3>
            <p class="portfolio-location">{c.data.location}</p>
            <p class="portfolio-desc">{c.data.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  text-align: center;
  max-width: 36rem;
  margin: 0 auto 3rem;
}
.page-header h1 { margin-bottom: 0.75rem; }
.page-header p { font-size: 1.0625rem; color: rgba(15, 14, 26, 0.6); }

.portfolio-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

.portfolio-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  transition: border-color 200ms, box-shadow 200ms, transform 200ms;
}
.portfolio-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.portfolio-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.tag {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-full);
  background: rgba(99, 102, 241, 0.08);
  color: var(--color-primary);
}

.portfolio-card h3 {
  font-size: 1.125rem;
  margin-bottom: 0.25rem;
}

.portfolio-location {
  font-size: 0.8125rem;
  color: rgba(15, 14, 26, 0.4);
  margin-bottom: 0.75rem;
}

.portfolio-desc {
  font-size: 0.875rem;
  color: rgba(15, 14, 26, 0.65);
  margin: 0;
  line-height: 1.6;
}

@media (min-width: 640px) {
  .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 900px) {
  .portfolio-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
